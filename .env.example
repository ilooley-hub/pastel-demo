# Copy to .env.local and fill in. Server-side values are never exposed to the
# client. On Vercel, set these in Project → Settings → Environment Variables.

# --- Required ---------------------------------------------------------------

# Anthropic API key for the query engine (server-only).
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Lead capture (Phase 6) -------------------------------------------------

# Neon Postgres connection string (server-only). When set, leads are stored in
# a `leads` table (auto-created on first write). The Neon Vercel integration
# also provides POSTGRES_URL, which is used as a fallback. Leave unset to run
# the demo without persistence (the form still works; leads are only logged).
DATABASE_URL=

# Optional: email the team on each new lead, via Resend (https://resend.com).
# Set BOTH the API key and at least one recipient to enable it.
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=          # recipient(s), comma-separated e.g. team@getpastel.ai
# Sender — must be on a Resend-verified domain in production. Defaults to
# "Pastel Demo <onboarding@resend.dev>" (works only to your own account email).
LEAD_FROM_EMAIL=

# Optional: a webhook to notify the team on each new lead. Works with a Slack
# incoming webhook out of the box (payload is { text, lead, stored }).
LEAD_NOTIFY_WEBHOOK=

# Optional: booking link shown on the lead confirmation step. Exposed to the
# client (NEXT_PUBLIC_), so use a public Calendly/scheduling URL.
NEXT_PUBLIC_CALENDLY_URL=

# --- Rate limiting (optional) -----------------------------------------------

# Per-IP rate limits protect this public, paid-API demo. Without these, an
# in-memory limiter is used (fine for dev / low traffic, per-instance only).
# For accurate distributed limits on Vercel, create an Upstash Redis DB (free)
# and set both — the limiter switches to Upstash automatically.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Serving under a sub-path (e.g. getpastel.ai/demo) -----------------------

# Base path the app is served under, behind a rewrite. Set to "/demo" on the
# demo's Vercel project so it serves at <domain>/demo and getpastel.ai can
# rewrite /demo/* to it. Leave unset for local dev (served at /).
NEXT_PUBLIC_BASE_PATH=
